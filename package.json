{
  "name": "auto-agent-template",
  "version": "1.0.0",
  "description": "go.md를 읽고 토큰이 소진될 때까지 자율 실행하는 멀티 에이전트 템플릿",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "make-design": "node src/makeDesign.js",
    "make-task": "node src/makeTask.js",
    "db-save-task": "node src/dbSaveTask.js",
    "db-delete": "node src/dbDeleteTask.js",
    "go": "pnpm run make-design && pnpm run make-task && pnpm run db-save-task && pnpm run start"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/mcp-adapters": "^1.1.3",
    "dotenv": "^16.4.0",
    "glob": "^11.0.0",
    "zod": "^3.23.0"
  }
}
