{
  "name": "ai-template",
  "version": "1.0.0",
  "description": "goal.md를 읽고 토큰이 소진될 때까지 자율 실행하는 멀티 에이전트 템플릿",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "make-design": "node src/makeDesign.js",
    "make-task": "node src/makeTask.js",
    "db-delete": "node src/dbDeleteTask.js",
    "init:start": "pnpm run make-design && pnpm run make-task && pnpm run start",
    "init:env": "bash scripts/init-env.sh",
    "lock:src": "bash scripts/lock-src.sh",
    "unlock:src": "bash scripts/unlock-src.sh"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/mcp-adapters": "^1.1.3",
    "dotenv": "^16.4.0",
    "glob": "^11.0.0",
    "zod": "^3.23.0"
  }
}
