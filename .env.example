# =====================================================
# 자율 에이전트 실행 템플릿 환경 설정
# .env.example을 복사하여 .env로 사용하세요
# =====================================================

# ─────────────────────────────────────────────────────
# AI CLI 설정 (각 에이전트에 사용할 AI 선택)
# 가능한 값: claude | gemini | codex | agent | copilot | ollama
# agent   사용 시 사전 설정: agent login
# copilot 사용 시 사전 설정: gh auth login && gh extension install github/gh-copilot
# ─────────────────────────────────────────────────────

# Supervisor: 다음에 실행할 에이전트를 결정
SUPERVISOR_AI=codex

# Worker: goal.md의 태스크를 실행하는 에이전트
WORKER_AI=codex

# ─────────────────────────────────────────────────────
# 실행 입력 소스 설정
# ─────────────────────────────────────────────────────

# 실행 모드 (고정):
# - infinite-context : goal.md + agent.md를 기반으로 MCP 메모리 중심 자율 주행 (목표·제약은 goal.md에 통합)
EXECUTION_MODE=infinite-context

# goal.md 파일 경로 (목표·태스크·제약의 단일 기준)
GO_FILE=./goal.md

# infinite-context 모드에서 읽을 에이전트 지시 파일
AGENT_FILE=./agent.md

# (선택) 디자인/기획 마크다운 폴더 — 아래 glob에 맞는 .md 전체가 goal.md 지시 뒤에 자동 주입됨
# 비우면 주입 안 함
DESIGN_DIR=./design
# make-design 입력 goal 파일 (기본: GO_FILE 또는 ./goal.md)
# DESIGN_SOURCE_GOAL_FILE=./goal.md
# make-design 세션당 생성할 design 파일 수 (컨텍스트 절약용)
# DESIGN_MAX_FILES_PER_SESSION=3
# DESIGN_GLOB=**/*.md
# DESIGN_MAX_CHARS_PER_FILE=200000
# make-task 출력 폴더
# TASK_DIR=./task
# make-task에 사용할 AI (미설정 시 WORKER_AI)
# TASK_AI=claude
# make-task에서 design 문서 파일당 최대 입력 길이
# TASK_SOURCE_MAX_CHARS=200000
# make-task 세션당 생성할 task 파일 수 (컨텍스트 절약용)
# TASK_MAX_FILES_PER_SESSION=3
# db-save-task 대상 패턴/길이
# TASK_GLOB=**/*.md
# TASK_DB_SAVE_MAX_CHARS=200000

# ─────────────────────────────────────────────────────
# 실행 제어
# ─────────────────────────────────────────────────────

# 자율 에이전트(CLI worker)가 src/를 수정하는 것을 프롬프트상 허용할지 (기본: 금지)
# true로 두면 worker 프롬프트에서 src 편집 예외가 켜짐 — 디버그·긴급 수정용
# ALLOW_AGENT_SRC_EDIT=false

# OS 차원에서 같은 사용자 프로세스의 쓰기까지 막으려면 에이전트 실행 전:
#   pnpm run lock:src
# 로컬에서 src 편집 시:
#   pnpm run unlock:src

# 자동 재시작: 사이클 완료 또는 토큰 한도 도달 시 자동으로 새 세션(새 채팅) 시작
# true  → 사이클 후 자동으로 새 Node 프로세스를 스폰하여 남은 작업을 이어받음
# false → 사이클 종료 후 수동으로 npm start를 다시 실행해야 함
AUTO_RESTART=true

# 연속 실행 모드: true이면 모든 태스크 완료 후 처음부터 반복
# false이면 모든 태스크 완료 시 종료
CONTINUOUS_MODE=false

# Worker 에이전트 반복 횟수 (각 태스크당 실행 회수)
WORKER_ITERATIONS=3
# true일 때만 start 시 "모든 테스트 완료" 태스크를 추가 (기본: 추가 안 함 — 소설/기획 템플릿용)
ENFORCE_TEST_COMPLETION=false

# LangGraph 재귀 한도 (무한 루프 방지 최댓값)
RECURSION_LIMIT=5000

# ─────────────────────────────────────────────────────
# 타임아웃 설정 (밀리초)
# ─────────────────────────────────────────────────────

# 각 CLI 호출의 최대 대기 시간 (기본 30분)
CLI_TIMEOUT_MS=1800000

# ─────────────────────────────────────────────────────
# Ollama 폴백 설정 (CLI 실패 시 로컬 모델로 자동 전환)
# ─────────────────────────────────────────────────────

# Ollama 서버 URL (기본값: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Ollama 사용 모델
OLLAMA_MODEL=gemma4:31b
# gemma4:31b qwen3.6:35b-a3b

# ─────────────────────────────────────────────────────
# 핸드오프 설정 (이전 세션 이어받기)
# ─────────────────────────────────────────────────────

# 이전 세션의 핸드오프 파일 경로 (재시작 시 지정)
# 예: HANDOFF_FILE=./handoff/handoff_2026-04-13_10-00-00.md
HANDOFF_FILE=

# 핸드오프 파일 저장 디렉토리
HANDOFF_DIR=./handoff

# ─────────────────────────────────────────────────────
# 컨텍스트 한도 설정
# ─────────────────────────────────────────────────────

# 핸드오프 트리거 임계치 (0.0 ~ 1.0) — 아래 한도가 설정된 모델에만 적용됨
CONTEXT_THRESHOLD=0.9

# 각 모델별 최대 토큰 한도 (선택 사항)
# 설정하지 않으면 사용량만 표시되고 핸드오프 임계치 체크는 비활성화됨
# 설정하면 사용률(%)과 진행 바가 함께 표시되고 임계치 도달 시 핸드오프 트리거됨
# CLAUDE_CONTEXT_LIMIT=200000
# GEMINI_CONTEXT_LIMIT=1048576
# CODEX_CONTEXT_LIMIT=128000
AGENT_CONTEXT_LIMIT=128000
# COPILOT_CONTEXT_LIMIT=65536
# OLLAMA_CONTEXT_LIMIT=131072

# ─────────────────────────────────────────────────────
# npm / npx (infinite-context MCP)
# ─────────────────────────────────────────────────────
# ~/.npm 캐시 일부가 root 소유면 npx infinite-context 가 EACCES/EEXIST 로 실패합니다.
# 한 번 고치려면 터미널에서: sudo chown -R "$(whoami)" ~/.npm
# 또는 아래에 본인만 쓰는 캐시 경로를 지정 (미설정 시 loadEnv가 ~/.npm-cache-ai-template 사용)
# NPM_CONFIG_CACHE=/Users/you/.npm-cache-safe

# ─────────────────────────────────────────────────────
# 로그 설정
# ─────────────────────────────────────────────────────

# 상세 로그 출력 여부
VERBOSE=true
