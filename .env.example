# =====================================================
# 자율 에이전트 실행 템플릿 환경 설정
# .env.example을 복사하여 .env로 사용하세요
# =====================================================

# ─────────────────────────────────────────────────────
# AI CLI 설정 (각 에이전트에 사용할 AI 선택)
# 가능한 값: claude | gemini | codex
# ─────────────────────────────────────────────────────

# Supervisor: 다음에 실행할 에이전트를 결정
SUPERVISOR_AI=gemini

# Worker: go.md의 태스크를 실행하는 에이전트
WORKER_AI=claude

# ─────────────────────────────────────────────────────
# go.md 설정
# ─────────────────────────────────────────────────────

# 읽을 go.md 파일 경로 (기본값: ./go.md)
GO_FILE=./go.md

# ─────────────────────────────────────────────────────
# 실행 제어
# ─────────────────────────────────────────────────────

# 자동 재시작: 사이클 완료 또는 토큰 한도 도달 시 자동으로 새 세션(새 채팅) 시작
# true  → 사이클 후 자동으로 새 Node 프로세스를 스폰하여 남은 작업을 이어받음
# false → 사이클 종료 후 수동으로 npm start를 다시 실행해야 함
AUTO_RESTART=true

# 연속 실행 모드: true이면 모든 태스크 완료 후 처음부터 반복
# false이면 모든 태스크 완료 시 종료
CONTINUOUS_MODE=false

# Worker 에이전트 반복 횟수 (각 태스크당 실행 회수)
WORKER_ITERATIONS=1

# LangGraph 재귀 한도 (무한 루프 방지 최댓값)
RECURSION_LIMIT=5000

# ─────────────────────────────────────────────────────
# 타임아웃 설정 (밀리초)
# ─────────────────────────────────────────────────────

# 각 CLI 호출의 최대 대기 시간 (기본 10분)
CLI_TIMEOUT_MS=600000

# ─────────────────────────────────────────────────────
# Ollama 폴백 설정 (CLI 실패 시 로컬 모델로 자동 전환)
# ─────────────────────────────────────────────────────

# Ollama 서버 URL (기본값: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Ollama 사용 모델
OLLAMA_MODEL=gemma3:12b

# ─────────────────────────────────────────────────────
# 핸드오프 설정 (이전 세션 이어받기)
# ─────────────────────────────────────────────────────

# 이전 세션의 핸드오프 파일 경로 (재시작 시 지정)
# 예: HANDOFF_FILE=./handoff/handoff_2026-04-13_10-00-00.md
HANDOFF_FILE=

# 핸드오프 파일 저장 디렉토리
HANDOFF_DIR=./handoff

# ─────────────────────────────────────────────────────
# 컨텍스트 한도 설정 (%)
# ─────────────────────────────────────────────────────

# 이 비율 이상 토큰 사용 시 핸드오프 트리거 (0.0 ~ 1.0)
CONTEXT_THRESHOLD=0.9

# ─────────────────────────────────────────────────────
# 로그 설정
# ─────────────────────────────────────────────────────

# 상세 로그 출력 여부
VERBOSE=true
